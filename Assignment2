<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>✦ CELESTIAL SHOWDOWN ✦ | Stone · Paper · Scissors</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      user-select: none;
    }

    body {
      min-height: 100vh;
      background: radial-gradient(circle at 30% 10%, #0a0f2a, #030617);
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Segoe UI', 'Poppins', 'Quicksand', system-ui, -apple-system, 'Orbitron', sans-serif;
      padding: 1.5rem;
      position: relative;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: absolute;
      width: 280px;
      height: 280px;
      background: radial-gradient(circle, rgba(255,215,150,0.2) 0%, rgba(255,100,200,0) 70%);
      top: 10%;
      left: -5%;
      border-radius: 50%;
      pointer-events: none;
      filter: blur(45px);
      z-index: 0;
    }

    body::after {
      content: '';
      position: absolute;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(80,180,255,0.15) 0%, rgba(0,0,0,0) 70%);
      bottom: -15%;
      right: -10%;
      border-radius: 50%;
      pointer-events: none;
      filter: blur(60px);
    }

    .game-container {
      position: relative;
      z-index: 10;
      backdrop-filter: blur(2px);
      max-width: 700px;
      width: 100%;
      background: rgba(12, 20, 35, 0.65);
      border-radius: 4rem 3rem 4rem 3rem;
      box-shadow: 0 30px 45px rgba(0, 0, 0, 0.5), 0 0 0 2px rgba(255, 220, 150, 0.2) inset, 0 0 20px rgba(210, 180, 255, 0.3);
      padding: 2rem 1.8rem 2.2rem;
      transition: all 0.3s ease;
      border: 1px solid rgba(255, 235, 200, 0.3);
    }

    .title-section {
      text-align: center;
      margin-bottom: 1.5rem;
    }

    .game-title {
      font-size: 2.6rem;
      font-weight: 800;
      background: linear-gradient(135deg, #FDE68A, #FFB347, #C084FC);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: 2px;
      text-shadow: 0 2px 5px rgba(0,0,0,0.3);
      display: inline-block;
      animation: gentlePulse 3s infinite ease;
    }

    .subtit {
      font-size: 0.85rem;
      color: #C9DDEE;
      letter-spacing: 3px;
      margin-top: 6px;
      font-weight: 300;
      text-transform: uppercase;
      background: rgba(0,0,0,0.3);
      display: inline-block;
      padding: 0.2rem 1rem;
      border-radius: 60px;
      backdrop-filter: blur(4px);
    }

    @keyframes gentlePulse {
      0% { opacity: 0.9; text-shadow: 0 0 0px #ffb347;}
      50% { opacity: 1; text-shadow: 0 0 8px #ffd966;}
      100% { opacity: 0.9; text-shadow: 0 0 0px #c084fc;}
    }

    .arena {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.8rem;
      margin: 2rem 0 1rem;
      flex-wrap: wrap;
    }

    .player-card, .ai-card {
      background: rgba(0, 0, 0, 0.55);
      backdrop-filter: blur(8px);
      border-radius: 2.5rem;
      padding: 1.2rem 0.8rem;
      flex: 1;
      text-align: center;
      box-shadow: 0 15px 25px rgba(0,0,0,0.3);
      transition: transform 0.2s ease;
      border: 1px solid rgba(255,255,210,0.2);
    }

    .player-card:hover, .ai-card:hover {
      transform: translateY(-5px);
      border-color: rgba(255,215,150,0.6);
    }

    .label {
      font-size: 1.4rem;
      font-weight: 600;
      background: linear-gradient(120deg, #e0e7ff, #fbc2c2);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: 1px;
    }

    .choice-icon {
      font-size: 5.2rem;
      margin: 0.7rem 0 0.4rem;
      filter: drop-shadow(0 8px 12px rgba(0,0,0,0.4));
      transition: all 0.2s cubic-bezier(0.2, 1.2, 0.4, 1);
      display: inline-block;
    }

    .choice-name {
      font-size: 1rem;
      font-weight: 500;
      background: #1E293B;
      display: inline-block;
      padding: 0.2rem 1rem;
      border-radius: 40px;
      color: #FFE4B5;
      letter-spacing: 1px;
    }

    .vs-divider {
      font-size: 2rem;
      font-weight: 800;
      background: rgba(255,210,128,0.2);
      width: 60px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 100%;
      backdrop-filter: blur(8px);
      font-family: monospace;
      color: #FFD966;
      text-shadow: 0 0 6px #ff9900;
      border: 1px solid #ffcd94;
    }

    .choices-panel {
      display: flex;
      justify-content: center;
      gap: 1.8rem;
      margin: 2rem 0 1.8rem;
      flex-wrap: wrap;
    }

    .choice-btn {
      background: rgba(25, 35, 65, 0.8);
      backdrop-filter: blur(12px);
      border: none;
      width: 110px;
      padding: 0.9rem 0;
      border-radius: 60px;
      cursor: pointer;
      transition: 0.2s all ease;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      font-weight: bold;
      font-size: 2rem;
      color: #f0f3fa;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.25);
      border: 1px solid rgba(255,210,150,0.4);
    }

    .choice-btn span {
      font-size: 0.8rem;
      font-weight: 500;
      background: rgba(0,0,0,0.5);
      padding: 0.2rem 0.7rem;
      border-radius: 30px;
      letter-spacing: 1px;
    }

    .choice-btn:hover {
      transform: scale(1.03);
      background: rgba(55, 70, 110, 0.9);
      border-color: #ffcf8a;
      box-shadow: 0 0 12px #ffb347;
    }

    .choice-btn:active {
      transform: scale(0.97);
    }

    .result-area {
      background: rgba(0, 0, 0, 0.5);
      border-radius: 2rem;
      padding: 1rem;
      margin-top: 0.5rem;
      text-align: center;
    }

    .result-message {
      font-size: 1.6rem;
      font-weight: 700;
      background: linear-gradient(125deg, #FFF2D9, #FFD966);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 0 4px #ffbb77;
      letter-spacing: 1px;
      margin-bottom: 0.6rem;
      min-height: 4rem;
    }

    .score-board {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin: 0.8rem 0;
      font-weight: bold;
    }

    .score-item {
      background: #0a0f1e;
      padding: 0.4rem 1rem;
      border-radius: 60px;
      font-size: 1.2rem;
      display: flex;
      gap: 0.6rem;
      backdrop-filter: blur(4px);
    }

    .score-value {
      font-size: 1.7rem;
      font-weight: 800;
      background: linear-gradient(145deg, #FEE68E, #FFB347);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .reset-btn {
      background: rgba(0,0,0,0.6);
      border: 1px solid #ffcf8a;
      color: #FFE0A3;
      padding: 0.5rem 1.8rem;
      border-radius: 3rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 0.5rem;
      font-size: 1rem;
      transition: 0.2s;
      backdrop-filter: blur(8px);
    }

    .reset-btn:hover {
      background: #ffb34730;
      color: #ffffdd;
      border-color: #ffbc6e;
      letter-spacing: 1px;
    }

    .floating-particle {
      position: fixed;
      pointer-events: none;
      background: radial-gradient(circle, #ffdd99, #ffaa66);
      border-radius: 50%;
      opacity: 0;
      z-index: 999;
    }

    footer {
      font-size: 0.7rem;
      text-align: center;
      margin-top: 1.5rem;
      color: #7c8ba0;
    }

    @media (max-width: 550px) {
      .game-container { padding: 1.5rem; }
      .choice-btn { width: 80px; font-size: 1.6rem; }
      .choice-icon { font-size: 3.2rem; }
      .result-message { font-size: 1.2rem; }
      .vs-divider { width: 45px; height: 45px; font-size: 1.5rem; }
      .score-item { font-size: 1rem; }
      .score-value { font-size: 1.3rem; }
      .game-title { font-size: 2rem; }
    }
  </style>
</head>
<body>

<div class="game-container">
  <div class="title-section">
    <div class="game-title">✦ CELESTIAL THROW ✦</div>
    <div class="subtit">⚡ stone · paper · scissors ⚡</div>
  </div>

  <div class="arena">
    <div class="player-card">
      <div class="label">🌙 YOU</div>
      <div class="choice-icon" id="playerIcon">🪨</div>
      <div class="choice-name" id="playerChoiceName">STONE</div>
    </div>
    <div class="vs-divider">VS</div>
    <div class="ai-card">
      <div class="label">✨ COSMOS AI ✨</div>
      <div class="choice-icon" id="aiIcon">📄</div>
      <div class="choice-name" id="aiChoiceName">PAPER</div>
    </div>
  </div>

  <div class="choices-panel">
    <button class="choice-btn" data-move="stone">🪨 <span>• BASALT •</span></button>
    <button class="choice-btn" data-move="paper">📄 <span>• PARCHMENT •</span></button>
    <button class="choice-btn" data-move="scissors">✂️ <span>• ETHER BLADE •</span></button>
  </div>

  <div class="result-area">
    <div class="result-message" id="resultMsg">🌀 await your decree...</div>
    <div class="score-board">
      <div class="score-item">✨ YOU &nbsp;<span class="score-value" id="playerScore">0</span></div>
      <div class="score-item">🌌 COSMOS &nbsp;<span class="score-value" id="aiScore">0</span></div>
    </div>
    <button class="reset-btn" id="resetGame">⟳ RESET STARDUST ⟳</button>
  </div>
  <footer>✧ fate dances between stone, parchment & starblade ✧</footer>
</div>

<script>
  (function() {
    let playerScore = 0;
    let aiScore = 0;
    let roundActive = true;
    const moves = {
      stone: { name: "STONE", icon: "🪨", beats: "scissors" },
      paper: { name: "PAPER", icon: "📄", beats: "stone" },
      scissors: { name: "SCISSORS", icon: "✂️", beats: "paper" }
    };
    
    const moveKeys = ['stone', 'paper', 'scissors'];
    
    const playerIconEl = document.getElementById('playerIcon');
    const playerChoiceNameEl = document.getElementById('playerChoiceName');
    const aiIconEl = document.getElementById('aiIcon');
    const aiChoiceNameEl = document.getElementById('aiChoiceName');
    const resultMsgEl = document.getElementById('resultMsg');
    const playerScoreSpan = document.getElementById('playerScore');
    const aiScoreSpan = document.getElementById('aiScore');
    const resetBtn = document.getElementById('resetGame');
    const choiceBtns = document.querySelectorAll('.choice-btn');
    
    function updateScoreUI() {
      playerScoreSpan.innerText = playerScore;
      aiScoreSpan.innerText = aiScore;
    }
    
    function createCelebrationSpark(x, y, isPlayerVictory) {
      const containerRect = document.querySelector('.game-container').getBoundingClientRect();
      const centerX = containerRect.left + containerRect.width / 2;
      const centerY = containerRect.top + containerRect.height / 3;
      const particleCount = 16;
      for (let i = 0; i < particleCount; i++) {
        const particle = document.createElement('div');
        particle.classList.add('floating-particle');
        const size = Math.random() * 8 + 4;
        particle.style.width = size + 'px';
        particle.style.height = size + 'px';
        particle.style.background = isPlayerVictory 
          ? `radial-gradient(circle, #FFDD88, #FFAA44)` 
          : `radial-gradient(circle, #88AAFF, #4466CC)`;
        const angle = Math.random() * Math.PI * 2;
        const radius = Math.random() * 70 + 20;
        const xOffset = Math.cos(angle) * radius;
        const yOffset = Math.sin(angle) * radius;
        particle.style.left = (centerX + xOffset) + 'px';
        particle.style.top = (centerY + yOffset) + 'px';
        particle.style.opacity = '0.8';
        particle.style.transition = 'all 0.9s ease-out';
        particle.style.boxShadow = '0 0 8px gold';
        document.body.appendChild(particle);
        
        requestAnimationFrame(() => {
          particle.style.transform = `translateY(${-40 + (Math.random() * 30)}px) translateX(${(Math.random() - 0.5) * 50}px)`;
          particle.style.opacity = '0';
        });
        setTimeout(() => {
          particle.remove();
        }, 900);
      }
    }
    
    function animateIcon(element, isPlayer = true) {
      if (!element) return;
      element.style.transform = 'scale(1.2)';
      element.style.transition = 'transform 0.12s cubic-bezier(0.2, 1.4, 0.5, 1)';
      setTimeout(() => {
        element.style.transform = 'scale(1)';
      }, 150);
      const parentCard = isPlayer ? document.querySelector('.player-card') : document.querySelector('.ai-card');
      if (parentCard) {
        parentCard.style.transition = 'background 0.2s';
        parentCard.style.background = 'rgba(255,215,140,0.25)';
        setTimeout(() => {
          parentCard.style.background = '';
        }, 200);
      }
    }
    
    function playRound(playerMove) {
      if (!roundActive) return;
      
      const aiRandomMove = moveKeys[Math.floor(Math.random() * moveKeys.length)];
      const playerMoveData = moves[playerMove];
      const aiMoveData = moves[aiRandomMove];
      
      playerIconEl.innerText = playerMoveData.icon;
      playerChoiceNameEl.innerText = playerMoveData.name;
      aiIconEl.innerText = aiMoveData.icon;
      aiChoiceNameEl.innerText = aiMoveData.name;
      
      animateIcon(playerIconEl, true);
      animateIcon(aiIconEl, false);
      
      let result = '';
      let roundWinner = null;
      
      if (playerMove === aiRandomMove) {
        result = `⚖️ MYSTIC TIE ⚖️ · Both chose ${playerMoveData.name}`;
        roundWinner = 'tie';
      } else if (playerMoveData.beats === aiRandomMove) {
        playerScore++;
        result = `✨ VICTORY! ✨ Your ${playerMoveData.name} shatters ${aiMoveData.name}. +1 Starlight!`;
        roundWinner = 'player';
      } else {
        aiScore++;
        result = `🌪️ COSMOS STRIKES 🌪️ · ${aiMoveData.name} overcomes your ${playerMoveData.name}.`;
        roundWinner = 'ai';
      }
      
      updateScoreUI();
      resultMsgEl.innerHTML = result;
      
      if (roundWinner === 'player') {
        createCelebrationSpark(0, 0, true);
        resultMsgEl.style.transform = 'scale(1.01)';
        setTimeout(() => { resultMsgEl.style.transform = ''; }, 300);
      } else if (roundWinner === 'ai') {
        createCelebrationSpark(0, 0, false);
        resultMsgEl.style.transform = 'scale(0.99)';
        setTimeout(() => { resultMsgEl.style.transform = ''; }, 300);
      } else {
        resultMsgEl.style.textShadow = '0 0 6px #c0c0ff';
        setTimeout(() => { resultMsgEl.style.textShadow = ''; }, 400);
      }
      
      if (playerScore === 5 || aiScore === 5) {
        const winnerMsg = playerScore === 5 ? "🏆 YOU REACHED ETHER SUPREMACY! 🏆" : "🌀 COSMOS ACHIEVED GALACTIC VICTORY 🌀";
        resultMsgEl.innerHTML = `${winnerMsg}<br>✨ ${result} ✨<br> click RESET to reforge fate`;
        if (playerScore === 5 || aiScore === 5) {
          choiceBtns.forEach(btn => {
            btn.style.pointerEvents = 'auto';
          });
          document.querySelector('.game-container').style.boxShadow = '0 0 0 3px gold, 0 0 25px gold';
          setTimeout(() => {
            if(playerScore === 5 || aiScore === 5) return;
          }, 500);
        }
      } else {
        document.querySelector('.game-container').style.boxShadow = '';
      }
      
      if (playerScore !== 5 && aiScore !== 5) {
      } else {
        createCelebrationSpark(0,0, playerScore ===5);
        if (playerScore===5) {
          for(let i=0;i<12;i++) createCelebrationSpark(0,0,true);
        } else if (aiScore===5){
          for(let i=0;i<12;i++) createCelebrationSpark(0,0,false);
        }
      }
    }
    
    function resetGame() {
      playerScore = 0;
      aiScore = 0;
      updateScoreUI();
      
      playerIconEl.innerText = "🪨";
      playerChoiceNameEl.innerText = "STONE";
      aiIconEl.innerText = "📄";
      aiChoiceNameEl.innerText = "PAPER";
      resultMsgEl.innerHTML = "🌀 GAME REFRESHED · MAKE YOUR MOVE 🌀";
      choiceBtns.forEach(btn => {
        btn.style.pointerEvents = 'auto';
      });
      document.querySelector('.game-container').style.boxShadow = '';
      const container = document.querySelector('.game-container');
      container.style.transform = 'scale(1.01)';
      setTimeout(() => { container.style.transform = ''; }, 200);
    }
    
    choiceBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const moveAttr = btn.getAttribute('data-move');
        if (moveAttr && (playerScore < 5 && aiScore < 5)) {
          playRound(moveAttr);
        } else {
          if (playerScore >=5 || aiScore >=5) {
            resultMsgEl.innerHTML = "🏁 EPILOGUE REACHED · PRESS RESET TO START NEW SAGA 🏁";
            resultMsgEl.style.animation = 'gentlePulse 0.8s';
            setTimeout(() => { if (playerScore>=5||aiScore>=5) {} }, 700);
          } else {
            playRound(moveAttr);
          }
        }
      });
    });
    
    resetBtn.addEventListener('click', () => {
      resetGame();
    });
    
    resetGame();
    
    document.body.addEventListener('mousemove', (e) => {
      if (Math.random() > 0.97) {
        const aura = document.createElement('div');
        aura.style.position = 'fixed';
        aura.style.left = e.clientX + 'px';
        aura.style.top = e.clientY + 'px';
        aura.style.width = '6px';
        aura.style.height = '6px';
        aura.style.background = 'radial-gradient(circle, #ffcc88, #ffaa55)';
        aura.style.borderRadius = '50%';
        aura.style.pointerEvents = 'none';
        aura.style.zIndex = '9999';
        aura.style.opacity = '0.7';
        aura.style.filter = 'blur(2px)';
        document.body.appendChild(aura);
        setTimeout(() => {
          aura.style.opacity = '0';
          aura.style.transform = 'scale(2)';
          setTimeout(() => aura.remove(), 300);
        }, 200);
      }
    });
    
    window.addEventListener('resize', () => {});
  })();
</script>
</body>
</html>
